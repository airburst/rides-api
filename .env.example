# Database
DATABASE_URL=postgres://user:password@host:5432/database

# Production DB for pumping data (copy from production .env)
SOURCE_URL=

# Multi-tenant support
# Fallback club when X-Club_Id header is missing or invalid (compat mode)
DEFAULT_CLUB_SLUG=bcc
# Set to true to enable strict tenancy; will return 400 instead
# of falling back to default (single) club
STRICT_TENANCY=false

# Auth0
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_AUDIENCE=https://api.your-app.com

# better-auth
BETTER_AUTH_SECRET=dev-secret-change-before-production-atleast32chars
BETTER_AUTH_URL=http://localhost:3001
COOKIE_DOMAIN=localhost
EMAIL_PROVIDER=console
EMAIL_FROM=noreply@fairhursts.net
# RESEND_API_KEY= (required when EMAIL_PROVIDER=resend)

# Server
PORT=3001
NODE_ENV=development

# Cron APIs - accessed with API_KEY
API_KEY=

# RiderHQ membership sync
RIDERHQ_URL=https://www.riderhq.com
RIDERHQ_ACCOUNT_ID=
RIDERHQ_PRIVATE_KEY=

# Redis Cache
REDIS_URL=redis://localhost:6379
CACHE_ENABLED=true
CACHE_TTL=300

# Local dev only — bypass Auth0 and inject a superadmin user.
# Server returns 500 from /any route if NODE_ENV=production while these are set.
# Leave empty in any non-dev environment.
DEV_SKIP_AUTH=
DEV_SKIP_AUTH_USER=a-superuser-email
