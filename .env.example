# Database
DATABASE_URL=postgres://user:password@host:5432/database

# Production DB for pumping data (copy from production .env)
SOURCE_URL=

# Multi-tenant support
# Fallback club when X-Club_Id header is missing or invalid (compat mode)
DEFAULT_CLUB_SLUG=bcc
# Set to true to enable strict tenancy; will return 400 instead
# of falling back to default (single) club
STRICT_TENANCY=false

# Auth0
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_AUDIENCE=https://api.your-app.com

# Server
PORT=3001
NODE_ENV=development

# Cron APIs - accessed with API_KEY
API_KEY=

# RiderHQ membership sync
RIDERHQ_URL=https://www.riderhq.com
RIDERHQ_ACCOUNT_ID=
RIDERHQ_PRIVATE_KEY=

# Redis Cache
REDIS_URL=redis://localhost:6379
CACHE_ENABLED=true
CACHE_TTL=300
