{
  "name": "rides-api",
  "version": "2.3.5",
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "tsc",
    "start": "bun src/index.ts",
    "test": "bun test",
    "lint": "eslint --fix",
    "format": "prettier --write .",
    "check": "prettier --write . && eslint --fix",
    "check-types": "tsc --noEmit",
    "deploy": "ssh -i ~/.ssh/oracle-rides-key ubuntu@143.47.251.53 'cd ~/rides-api && git pull && /home/ubuntu/.bun/bin/bun install --production && /home/ubuntu/.bun/bin/bun run db:migrate && pm2 reload rides-api --update-env'",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:pump": "bun src/db/pump.ts",
    "db:seed": "DB_SEEDING=true bun src/db/seed.ts",
    "db:studio": "drizzle-kit studio",
    "startdb": "./bin/start-database",
    "startredis": "./bin/start-redis",
    "prepare": "husky || true",
    "changeset": "changeset",
    "version": "changeset version"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.2",
    "better-auth": "^1.6.13",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.18",
    "jose": "^6.2.3",
    "postgres": "^3.4.9",
    "redis": "^5.12.1",
    "resend": "^6.12.4",
    "rrule": "^2.8.1",
    "sharp": "^0.34.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.2",
    "@types/sharp": "^0.32.0",
    "bun-types": "^1.3.13",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.3.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "husky": "^9.1.7",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2"
  },
  "engines": {
    "bun": ">=1.0.0"
  }
}
